PORT=8080
ENABLE_EMAIL_FEATURE=true

# Gmail API settings (recommended for Render/free hosting)
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_google_oauth_refresh_token
GMAIL_SENDER_EMAIL=your.gmail.address@gmail.com
GMAIL_FROM="Rotary Diplome <your.gmail.address@gmail.com>"

# For production, set your frontend origin instead of *
CORS_ORIGIN=*
