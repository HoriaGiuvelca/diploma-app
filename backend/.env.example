PORT=8080

# SMTP settings (example values)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.smtp.username@gmail.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM="Rotary Diplome <your.smtp.username@gmail.com>"

# Set to 4 to force IPv4 when IPv6/network routing causes socket connection failures.
SMTP_FAMILY=0

# Set to false only for debugging TLS/certificate issues.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# For production, set your frontend origin instead of *
CORS_ORIGIN=*
